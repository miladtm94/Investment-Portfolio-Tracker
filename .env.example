# ─── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=invest
POSTGRES_PASSWORD=investpass
POSTGRES_DB=investment_platform

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
ENCRYPTION_KEY=your-aes-256-encryption-key-32b!
NEXTAUTH_SECRET=your-nextauth-secret

# ─── AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Market Data ─────────────────────────────────────────────────────────
POLYGON_API_KEY=your-polygon-api-key
COINGECKO_API_KEY=your-coingecko-api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ─── Broker Integration ──────────────────────────────────────────────────
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

SNAPTRADE_CLIENT_ID=your-snaptrade-client-id
SNAPTRADE_CONSUMER_KEY=your-snaptrade-consumer-key

# ─── Crypto Exchanges ────────────────────────────────────────────────────
KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_API_SECRET=your-kraken-api-secret
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# ─── Australian localisation ─────────────────────────────────────────────
# Tax jurisdiction: AU uses ATO rules (CGT discount, AU financial year)
DEFAULT_TAX_JURISDICTION=AU
DEFAULT_CURRENCY=AUD
DEFAULT_TIMEZONE=Australia/Sydney
# CGT discount: 0.50 for individuals, 0.3333 for SMSF trustees
CGT_DISCOUNT_RATE=0.50
# ATO financial year starts 1 July (month=7, day=1)
TAX_YEAR_START_MONTH=7
TAX_YEAR_START_DAY=1

# ─── App ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
NEXT_PUBLIC_API_URL=http://localhost:8010
NEXTAUTH_URL=http://localhost:3000

# Docker host ports. Container-to-container traffic still uses the normal
# internal ports, but these avoid clashes with other local projects.
BACKEND_PORT=8010
FRONTEND_PORT=3000
POSTGRES_PORT=15432
REDIS_PORT=16379
FLOWER_PORT=5555
